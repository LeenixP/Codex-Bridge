{
  "name": "codex-switch",
  "version": "1.2.0",
  "private": true,
  "description": "Protocol bridge for Codex desktop -- converts OpenAI Chat and Anthropic APIs to OpenAI Responses format.",
  "author": "LeenixP",
  "license": "MIT",
  "homepage": "https://github.com/LeenixP/Codex-Switch",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LeenixP/Codex-Switch.git"
  },
  "main": "src/electron/main.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "check": "node scripts/check-syntax.js",
    "test": "node test/unit-tests.js && node test/format-conversion.js && node test/thinking-parser.test.js && node test/proxy-integration.js && node test/anthropic-integration.js && node test/error-paths.js",
    "test:unit": "node test/unit-tests.js && node test/format-conversion.js && node test/thinking-parser.test.js",
    "test:integration": "node test/proxy-integration.js && node test/anthropic-integration.js && node test/error-paths.js",
    "lint": "eslint src/ test/",
    "format": "prettier --write \"src/**/*.js\" \"test/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\" \"test/**/*.js\"",
    "icons": "node scripts/generate-icons.js",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true});require('fs').rmSync('node_modules',{recursive:true,force:true});console.log('Cleaned dist/ and node_modules/')\"",
    "dist": "electron-builder && node scripts/prepare-release-assets.js && node scripts/gen-checksums.js",
    "dist:all": "electron-builder --win --linux --mac && node scripts/prepare-release-assets.js && node scripts/gen-checksums.js",
    "dist:win": "electron-builder --win && node scripts/prepare-release-assets.js && node scripts/gen-checksums.js",
    "dist:linux": "electron-builder --linux && node scripts/prepare-release-assets.js && node scripts/gen-checksums.js",
    "dist:mac": "electron-builder --mac && node scripts/prepare-release-assets.js && node scripts/gen-checksums.js",
    "dist:verify": "node scripts/verify-release-assets.js"
  },
  "build": {
    "appId": "io.github.leenixp.codex-switch",
    "productName": "Codex-Switch",
    "copyright": "Copyright 2026 LeenixP",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json",
      "LICENSE"
    ],
    "artifactName": "${productName}-v${version}-${os}-${arch}.${ext}",
    "win": {
      "icon": "src/ui/assets/icons/app.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-v${version}-Windows_Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "allowElevation": true,
      "runAfterFinish": false,
      "uninstallDisplayName": "Codex-Switch",
      "installerSidebar": false
    },
    "mac": {
      "icon": "src/ui/assets/icons/app-512.png",
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ],
      "artifactName": "${productName}-v${version}-macOS.${ext}"
    },
    "linux": {
      "icon": "src/ui/assets/icons/app.png",
      "category": "Development",
      "maintainer": "LeenixP <lipeng.dev@163.com>",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "artifactName": "${productName}-v${version}-Linux-${arch}.${ext}"
    },
    "publish": null
  },
  "devDependencies": {
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.0.0",
    "prettier": "^3.5.0",
    "sharp": "^0.34.5"
  },
  "dependencies": {
    "smol-toml": "^1.6.1",
    "undici": "^8.3.0"
  }
}
